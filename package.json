{
  "name": "chousei",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "npm run build:cf && wrangler dev",
    "deploy:cf": "npm run build:cf && opennextjs-cloudflare deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply chousei-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply chousei-db --local"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next": "16.2.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "uuid": "^13.0.0",
    "wrangler": "^4.81.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
